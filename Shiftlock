local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local StarterGui = game:GetService("StarterGui")

local player = Players.LocalPlayer
local isShiftlock = false

local function Notify(msg)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = "Shiftlock";
            Text = msg;
            Duration = 2;
        })
    end)
end

local function forceNativeShiftlock()
    player.DevEnableMouseLock = true
    
    player:GetPropertyChangedSignal("DevEnableMouseLock"):Connect(function()
        if not player.DevEnableMouseLock then
            player.DevEnableMouseLock = true
        end
    end)
    
    task.spawn(function()
        local PlayerScripts = player:WaitForChild("PlayerScripts")
        local PlayerModule = PlayerScripts:WaitForChild("PlayerModule")
        local CameraModule = PlayerModule:WaitForChild("CameraModule")
        local MouseLockController = CameraModule:WaitForChild("MouseLockController")
        
        local boundKeys = MouseLockController:FindFirstChild("BoundKeys")
        if not boundKeys then
            boundKeys = Instance.new("StringValue")
            boundKeys.Name = "BoundKeys"
            boundKeys.Parent = MouseLockController
        end
        boundKeys.Value = "R"
    end)
end

forceNativeShiftlock()

UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.R then
        isShiftlock = not isShiftlock
        if isShiftlock then
            Notify("ON")
        else
            Notify("OFF")
        end
    end
end)

player.CharacterAdded:Connect(function()
    task.wait(0.5)
    player.DevEnableMouseLock = true
    isShiftlock = false
end)
